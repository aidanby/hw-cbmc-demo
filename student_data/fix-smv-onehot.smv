-- One-hot FSM with 3 states forming a cycle: s0 -> s1 -> s2 -> s0.
-- The FSM is violating its one-hot invariant and transition rules.

MODULE main
VAR
  s0 : boolean;
  s1 : boolean;
  s2 : boolean;
ASSIGN
  init(s0) := TRUE;
  init(s1) := FALSE;
  init(s2) := FALSE;

  next(s0) := s2;
  next(s1) := s0 | s2; 
  next(s2) := s0;       

LTLSPEC G ((s0 & !s1 & !s2) | (!s0 & s1 & !s2) | (!s0 & !s1 & s2));
LTLSPEC G F s2;
LTLSPEC G (s1 -> X s2);
